{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/robots.txt", "destination": "/public/robots.txt" },
    { "source": "/sitemap.xml", "destination": "/public/sitemap.xml" }
  ],
  "redirects": [
    {
      "source": "/",
      "has": [
        {
          "type": "host",
          "value": "admin.derecepanel.com"
        }
      ],
      "destination": "/super-admin.html",
      "permanent": false
    },
    {
      "source": "/index.html",
      "destination": "/",
      "permanent": true
    }
  ]
}
